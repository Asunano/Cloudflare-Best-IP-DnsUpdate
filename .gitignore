# 运行时生成的配置文件（用户自定义）
conf/*.json
conf/status.conf
conf/.templates_downloaded

# 日志文件
logs/
*.log

# 锁文件
modules/*/.lock
modules/*/.core.lock
modules/*/.setup.lock
modules/*/.menu.lock

# IP 数据文件（运行时生成）
assets/data/cf-ip/result*.csv
assets/data/cf-dns/ip_list.txt
assets/data/dnspod-dns/*.txt

# cfst 程序二进制文件
assets/cfst/cfst

# 临时文件
*.tmp
*.temp
*~

# 系统文件
.DS_Store
Thumbs.db
