# 运行时生成的配置文件（用户自定义）
conf/*.json
conf/status.conf
conf/history.jsonl
conf/deployments.json

# 运行时标记文件
.restart_needed
.restart_count

# 日志文件
logs/
*.log

# 锁文件（匹配所有模块下的 .*.lock 文件）
modules/**/*.lock

# 部署版本特有的模块（原始仓库函数内联在 cfopt.sh 中）
modules/install/

# 运行时数据目录（测速结果、IP 列表等）
assets/data/

# cfst 程序二进制文件
assets/cfst/cfst

# 临时文件
*.tmp
*.temp
*~

# 系统文件
.DS_Store
Thumbs.db

# IDE 和编辑器配置
.lingma/
.vscode/
.idea/
.codebuddy/
